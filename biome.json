{
  "$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
  "files": {
    "includes": ["src/**/*.ts"]
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "a11y": {
        "recommended": true
      },
      "complexity": {
        "recommended": true,
        "noExcessiveCognitiveComplexity": "error"
      },
      "correctness": {
        "recommended": true,
        "noNodejsModules": "off",
        "useImportExtensions": "off"
      },
      "performance": {
        "recommended": true,
        "useTopLevelRegex": "off"
      },
      "security": {
        "recommended": true
      },
      "style": {
        "recommended": true,
        "noDefaultExport": "off",
        "useNamingConvention": "off",
        "noProcessEnv": "off",
        "noNonNullAssertion": "error",
        "useConst": "error",
        "useImportType": "error",
        "useExportType": "error",
        "useTemplate": "error",
        "useNodejsImportProtocol": "error",
        "useConsistentArrayType": {
          "level": "error",
          "options": { "syntax": "generic" }
        }
      },
      "suspicious": {
        "recommended": true,
        "noExplicitAny": "error",
        "noConsole": "off"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  }
}
